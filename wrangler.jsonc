{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "majsoul-graph",
  "main": "worker/src/index.ts",
  "compatibility_date": "2026-06-10",
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
