{
  "name": "majsoul-graph-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1 --port 5173",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "tsc -p tsconfig.json && vite build",
    "build:cloudflare": "npm run build:client && tsc -p worker/tsconfig.json --noEmit",
    "build:server": "tsc -p server/tsconfig.json --noEmit && tsup server/src/index.ts --format esm --platform node --target node24 --out-dir dist/server --clean false",
    "deploy:cloudflare": "npm run build:cloudflare && wrangler deploy",
    "dev:cloudflare": "npm run build:cloudflare && wrangler dev",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit && tsc -p worker/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "echarts": "^6.0.0",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260609.1",
    "@playwright/test": "^1.54.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^10.0.3",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.99.0"
  }
}
